---
interface Props {
  lang?: string;
  label?: string;
}
const { lang = "bash", label } = Astro.props;
---

<figure class="not-prose group relative my-4">
  {
    label && (
      <figcaption class="absolute top-2 right-3 font-mono text-[10px] tracking-wider text-slate-500 uppercase">
        {label}
      </figcaption>
    )
  }
  <pre
    class="overflow-x-auto rounded-lg border border-slate-300/60 bg-slate-950 p-4 text-sm leading-relaxed text-slate-100 dark:border-slate-800 dark:bg-slate-900/70"><code data-lang={lang}><slot /></code></pre>
</figure>
