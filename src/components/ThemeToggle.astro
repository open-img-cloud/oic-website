---
// SSR shell only; the client script below wires up the toggle and reflects state.
---

<button
  type="button"
  data-theme-toggle
  aria-label="Toggle theme"
  title="Toggle theme"
  class="inline-flex h-9 w-9 items-center justify-center rounded-md border border-slate-200 text-slate-600 transition-colors hover:border-slate-400 hover:text-slate-900 dark:border-slate-700 dark:text-slate-400 dark:hover:border-slate-500 dark:hover:text-slate-100"
>
  <!-- Sun icon (visible in dark mode → click to switch to light) -->
  <svg
    viewBox="0 0 24 24"
    class="hidden h-4 w-4 dark:block"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
    aria-hidden="true"
  >
    <circle cx="12" cy="12" r="4"></circle>
    <path
      d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"
    ></path>
  </svg>
  <!-- Moon icon (visible in light mode → click to switch to dark) -->
  <svg
    viewBox="0 0 24 24"
    class="h-4 w-4 dark:hidden"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
    aria-hidden="true"
  >
    <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
  </svg>
</button>

<script is:inline>
  (function () {
    const btn = document.querySelector("[data-theme-toggle]");
    if (!btn) return;
    btn.addEventListener("click", () => {
      const isDark = document.documentElement.classList.toggle("dark");
      try {
        localStorage.setItem("theme", isDark ? "dark" : "light");
      } catch {
        /* localStorage blocked — toggle still works for the session. */
      }
    });
  })();
</script>
