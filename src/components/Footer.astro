---
const year = new Date().getFullYear();
---

<footer class="border-t border-slate-800/60 bg-slate-950/60">
  <div
    class="mx-auto flex max-w-6xl flex-col gap-3 px-6 py-8 text-sm text-slate-400 sm:flex-row sm:items-center sm:justify-between"
  >
    <p>
      &copy; {year} Open Image Cloud — released under the{" "}
      <a class="underline hover:text-slate-100" href="https://www.apache.org/licenses/LICENSE-2.0"
        >Apache-2.0 license</a
      >.
    </p>
    <nav class="flex gap-4">
      <a class="hover:text-slate-100" href="https://github.com/open-img-cloud">GitHub</a>
      <a class="hover:text-slate-100" href="https://images.openimages.cloud/">Image registry</a>
    </nav>
  </div>
</footer>
