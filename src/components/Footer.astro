---
const year = new Date().getFullYear();
---

<footer
  class="dark:bg-navy-950/60 border-t border-slate-200/70 bg-slate-50/60 dark:border-slate-800/60"
>
  <div
    class="mx-auto flex max-w-6xl flex-col gap-3 px-6 py-8 text-sm text-slate-600 sm:flex-row sm:items-center sm:justify-between dark:text-slate-400"
  >
    <p>
      &copy; {year} Open Image Cloud — released under the{" "}
      <a
        class="underline hover:text-slate-900 dark:hover:text-slate-100"
        href="https://www.apache.org/licenses/LICENSE-2.0">Apache-2.0 license</a
      >.
    </p>
    <nav class="flex gap-4">
      <a
        class="hover:text-slate-900 dark:hover:text-slate-100"
        href="https://github.com/open-img-cloud">GitHub</a
      >
      <a
        class="hover:text-slate-900 dark:hover:text-slate-100"
        href="https://images.openimages.cloud/">Image registry</a
      >
    </nav>
  </div>
</footer>
