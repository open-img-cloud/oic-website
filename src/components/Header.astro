---
import { Image } from "astro:assets";
import logoIcon from "~/assets/open-images-icon.png";

const links = [
  { href: "/images/", label: "Images" },
  { href: "https://github.com/open-img-cloud", label: "GitHub", external: true },
];
const currentPath = Astro.url.pathname;
---

<header class="bg-navy-950/80 sticky top-0 z-20 border-b border-slate-800/60 backdrop-blur">
  <div class="mx-auto flex max-w-6xl items-center justify-between px-6 py-3">
    <a
      href="/"
      class="group flex items-center gap-2.5 font-semibold tracking-tight transition-opacity hover:opacity-90"
    >
      <Image
        src={logoIcon}
        alt=""
        width={36}
        height={36}
        loading="eager"
        class="h-9 w-9 drop-shadow-[0_2px_8px_rgba(91,141,239,0.25)]"
      />
      <span>Open Image Cloud</span>
    </a>
    <nav class="flex items-center gap-6 text-sm">
      {
        links.map((link) => {
          const isActive = !link.external && currentPath.startsWith(link.href);
          return (
            <a
              href={link.href}
              class:list={[
                "transition-colors",
                isActive ? "text-slate-50" : "text-slate-400 hover:text-slate-100",
              ]}
              {...(link.external ? { rel: "noopener", target: "_blank" } : {})}
            >
              {link.label}
            </a>
          );
        })
      }
    </nav>
  </div>
</header>
