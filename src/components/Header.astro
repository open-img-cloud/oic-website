---
const links = [
  { href: "/images/", label: "Images" },
  { href: "https://github.com/open-img-cloud", label: "GitHub", external: true },
];
const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 z-10 border-b border-zinc-800/60 bg-zinc-950/80 backdrop-blur">
  <div class="mx-auto flex max-w-6xl items-center justify-between px-6 py-4">
    <a href="/" class="flex items-center gap-2 font-semibold tracking-tight">
      <span
        class="from-brand-500 to-brand-700 inline-block h-6 w-6 rounded bg-gradient-to-br"
        aria-hidden="true"></span>
      <span>Open Image Cloud</span>
    </a>
    <nav class="flex items-center gap-6 text-sm">
      {
        links.map((link) => {
          const isActive = !link.external && currentPath.startsWith(link.href);
          return (
            <a
              href={link.href}
              class:list={[
                "transition-colors",
                isActive ? "text-zinc-50" : "text-zinc-400 hover:text-zinc-100",
              ]}
              {...(link.external ? { rel: "noopener", target: "_blank" } : {})}
            >
              {link.label}
            </a>
          );
        })
      }
    </nav>
  </div>
</header>
