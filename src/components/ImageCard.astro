---
import type { EnrichedImage } from "~/lib/images";

interface Props {
  image: EnrichedImage;
}

const { image } = Astro.props;
const variantCount = image.enrichedVariants.length;
const signed =
  image.enrichedManifest?.signed ?? image.enrichedVariants.some((v) => v.manifest?.signed) ?? false;
---

<a
  href={`/images/${image.os_name}/`}
  class="group hover:border-brand-500/60 flex flex-col gap-3 rounded-xl border border-slate-200 bg-white p-6 shadow-sm transition-colors hover:bg-slate-50 dark:border-slate-800 dark:bg-slate-900/40 dark:shadow-none dark:hover:bg-slate-900/80"
>
  <div class="flex items-baseline justify-between gap-3">
    <h3 class="text-lg font-semibold tracking-tight text-slate-900 dark:text-slate-50">
      {image.title}
    </h3>
    <span class="font-mono text-xs text-slate-500 dark:text-slate-400">{image.latest_version}</span>
  </div>
  <p class="text-sm text-slate-600 dark:text-slate-400">{image.tagline}</p>
  <div class="mt-auto flex flex-wrap items-center gap-2 pt-2 text-xs">
    <span
      class="rounded-md border border-slate-200 bg-slate-100 px-2 py-0.5 font-mono text-slate-600 dark:border-slate-700 dark:bg-slate-800/50 dark:text-slate-300"
    >
      {image.format}
    </span>
    <span
      class="rounded-md border border-slate-200 bg-slate-100 px-2 py-0.5 font-mono text-slate-600 dark:border-slate-700 dark:bg-slate-800/50 dark:text-slate-300"
    >
      {image.arch}
    </span>
    {
      variantCount > 0 && (
        <span class="rounded-md border border-slate-200 bg-slate-100 px-2 py-0.5 text-slate-600 dark:border-slate-700 dark:bg-slate-800/50 dark:text-slate-300">
          {variantCount} variant{variantCount > 1 ? "s" : ""}
        </span>
      )
    }
    {
      signed && (
        <span class="rounded-md border border-emerald-300/60 bg-emerald-50 px-2 py-0.5 text-emerald-700 dark:border-emerald-700/60 dark:bg-emerald-900/30 dark:text-emerald-300">
          cosign signed
        </span>
      )
    }
  </div>
</a>
