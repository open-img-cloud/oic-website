---
import type { EnrichedImage } from "~/lib/images";

interface Props {
  image: EnrichedImage;
}

const { image } = Astro.props;
const variantCount = image.enrichedVariants.length;
const signed =
  image.enrichedManifest?.signed ?? image.enrichedVariants.some((v) => v.manifest?.signed) ?? false;
---

<a
  href={`/images/${image.os_name}/`}
  class="group hover:border-brand-500/60 flex flex-col gap-3 rounded-xl border border-zinc-800 bg-zinc-900/40 p-6 transition-colors hover:bg-zinc-900/80"
>
  <div class="flex items-baseline justify-between gap-3">
    <h3 class="text-lg font-semibold tracking-tight text-zinc-50">{image.title}</h3>
    <span class="font-mono text-xs text-zinc-400">{image.latest_version}</span>
  </div>
  <p class="text-sm text-zinc-400">{image.tagline}</p>
  <div class="mt-auto flex flex-wrap items-center gap-2 pt-2 text-xs">
    <span
      class="rounded-md border border-zinc-700 bg-zinc-800/50 px-2 py-0.5 font-mono text-zinc-300"
    >
      {image.format}
    </span>
    <span
      class="rounded-md border border-zinc-700 bg-zinc-800/50 px-2 py-0.5 font-mono text-zinc-300"
    >
      {image.arch}
    </span>
    {
      variantCount > 0 && (
        <span class="rounded-md border border-zinc-700 bg-zinc-800/50 px-2 py-0.5 text-zinc-300">
          {variantCount} variant{variantCount > 1 ? "s" : ""}
        </span>
      )
    }
    {
      signed && (
        <span class="rounded-md border border-emerald-700/60 bg-emerald-900/30 px-2 py-0.5 text-emerald-300">
          cosign signed
        </span>
      )
    }
  </div>
</a>
