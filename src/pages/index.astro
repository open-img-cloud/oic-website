---
import { Image } from "astro:assets";
import Base from "~/layouts/Base.astro";
import { loadEnrichedImages } from "~/lib/images";
import ImageCard from "~/components/ImageCard.astro";
import logoIcon from "~/assets/open-images-icon.png";

const images = await loadEnrichedImages();
const featured = images.slice(0, 3);
---

<Base title="Open Image Cloud">
  <section class="relative overflow-hidden">
    <div
      aria-hidden="true"
      class="pointer-events-none absolute inset-0 -z-10 bg-[radial-gradient(ellipse_60%_50%_at_50%_0%,color-mix(in_oklch,var(--color-brand-500)_18%,transparent)_0%,transparent_70%)]"
    >
    </div>
    <div
      class="mx-auto grid max-w-6xl gap-12 px-6 py-20 sm:py-28 lg:grid-cols-[1.2fr_1fr] lg:items-center"
    >
      <div>
        <p class="text-brand-300 font-mono text-xs tracking-widest uppercase">
          open source · signed · reproducible
        </p>
        <h1
          class="mt-4 text-4xl leading-tight font-semibold tracking-tight text-slate-50 sm:text-5xl lg:text-6xl"
        >
          Cloud images
          <span
            class="from-brand-300 via-brand-500 to-brand-300 bg-gradient-to-r bg-clip-text text-transparent"
            >you can actually trust.</span
          >
        </h1>
        <p class="mt-6 max-w-2xl text-lg text-slate-300/90">
          Cloud-init-ready, <strong class="font-semibold text-slate-100">signed</strong>,
          reproducible qcow2 images for OpenStack and Proxmox — built in the open on GitHub Actions,
          with keyless cosign signatures and a public manifest for every release.
        </p>
        <div class="mt-8 flex flex-wrap gap-3">
          <a
            href="/images/"
            class="bg-brand-500 hover:bg-brand-600 inline-flex items-center gap-2 rounded-md px-5 py-2.5 text-sm font-medium text-slate-50 shadow-[0_8px_24px_-12px_rgba(91,141,239,0.6)] transition-colors"
          >
            Browse the catalog
            <svg viewBox="0 0 16 16" class="h-3.5 w-3.5" fill="none" aria-hidden="true">
              <path
                d="M9.5 3.5l4 4-4 4M2 7.5h11"
                stroke="currentColor"
                stroke-width="1.5"
                stroke-linecap="round"
                stroke-linejoin="round"></path>
            </svg>
          </a>
          <a
            href="https://github.com/open-img-cloud"
            class="inline-flex items-center gap-2 rounded-md border border-slate-700 px-5 py-2.5 text-sm font-medium text-slate-200 transition-colors hover:border-slate-500 hover:bg-slate-900/40 hover:text-slate-50"
          >
            <svg viewBox="0 0 16 16" class="h-4 w-4" fill="currentColor" aria-hidden="true">
              <path
                d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0 0 16 8c0-4.42-3.58-8-8-8z"
              ></path>
            </svg>
            View on GitHub
          </a>
        </div>
      </div>
      <div class="relative flex items-center justify-center lg:justify-end">
        <div
          aria-hidden="true"
          class="absolute inset-0 -z-10 bg-[radial-gradient(circle_at_center,color-mix(in_oklch,var(--color-brand-500)_22%,transparent)_0%,transparent_60%)] blur-2xl"
        >
        </div>
        <Image
          src={logoIcon}
          alt="Open Image Cloud logo"
          width={420}
          height={420}
          loading="eager"
          class="w-64 max-w-full sm:w-80 lg:w-[26rem]"
        />
      </div>
    </div>
  </section>

  <section class="bg-navy-900/30 border-t border-slate-800/60">
    <div class="mx-auto grid max-w-6xl gap-8 px-6 py-20 sm:grid-cols-3">
      <div>
        <div
          class="bg-brand-500/15 text-brand-300 inline-flex h-9 w-9 items-center justify-center rounded-md"
        >
          <svg
            viewBox="0 0 24 24"
            class="h-5 w-5"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path d="M21 12a9 9 0 1 1-9-9 9 9 0 0 1 9 9z"></path>
            <path d="M12 7v5l3 2"></path>
          </svg>
        </div>
        <h3 class="mt-4 text-base font-semibold text-slate-100">Reproducible</h3>
        <p class="mt-2 text-sm text-slate-400">
          Every release is built from a pinned upstream source and a tagged builder container. The
          exact commit, run URL and builder digest are embedded in the per-image
          <code class="font-mono text-xs">MANIFEST.json</code>.
        </p>
      </div>
      <div>
        <div
          class="inline-flex h-9 w-9 items-center justify-center rounded-md bg-emerald-500/15 text-emerald-300"
        >
          <svg
            viewBox="0 0 24 24"
            class="h-5 w-5"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
            <path d="M9 12l2 2 4-4"></path>
          </svg>
        </div>
        <h3 class="mt-4 text-base font-semibold text-slate-100">Signed</h3>
        <p class="mt-2 text-sm text-slate-400">
          Keyless <code class="font-mono text-xs">cosign</code> signatures via GitHub OIDC. Verify any
          image with a single command — no key management on your side.
        </p>
      </div>
      <div>
        <div
          class="bg-brand-700/25 text-brand-300 inline-flex h-9 w-9 items-center justify-center rounded-md"
        >
          <svg
            viewBox="0 0 24 24"
            class="h-5 w-5"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path d="M17.5 19a4.5 4.5 0 0 0 0-9 7 7 0 0 0-13.5 2.5A4.5 4.5 0 0 0 6 19"></path>
          </svg>
        </div>
        <h3 class="mt-4 text-base font-semibold text-slate-100">Open infrastructure</h3>
        <p class="mt-2 text-sm text-slate-400">
          Source of truth on a self-hosted Garage cluster, mirrored to Cloudflare R2 behind a public
          CDN. Reusable workflows in
          <a
            href="https://github.com/open-img-cloud/.github"
            class="text-brand-300 underline-offset-2 hover:underline">.github</a
          >
          power every image repo.
        </p>
      </div>
    </div>
  </section>

  <section class="border-t border-slate-800/60">
    <div class="mx-auto max-w-6xl px-6 py-20">
      <div class="flex items-baseline justify-between">
        <h2 class="text-2xl font-semibold tracking-tight text-slate-50">Featured images</h2>
        <a href="/images/" class="text-brand-300 hover:text-brand-500 text-sm">All images →</a>
      </div>
      <div class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {featured.map((image) => <ImageCard image={image} />)}
      </div>
    </div>
  </section>
</Base>
