---
import Base from "~/layouts/Base.astro";
import { loadEnrichedImages } from "~/lib/images";
import ImageCard from "~/components/ImageCard.astro";
import Terminal from "~/components/Terminal.astro";

const images = await loadEnrichedImages();
const featured = images.slice(0, 3);

// Pick the first image with a known filename for the snippet (falls back to a placeholder).
const sample = images[0];
const sampleVariant = sample?.enrichedVariants[0];
const sampleFile =
  sampleVariant?.filename ?? sample?.filename ?? "alpaquita-2026.04.14-glibc-x86_64.qcow2";
const sampleRepo = sample?.repo ?? "open-img-cloud/alpaquita-linux";
const sampleVersion = sample?.latest_version ?? "2026.04.14";
const sampleOs = sample?.os_name ?? "alpaquita-linux";
---

<Base title="Open Image Cloud">
  <section class="relative overflow-hidden">
    <div
      aria-hidden="true"
      class="pointer-events-none absolute inset-0 -z-10 bg-[radial-gradient(ellipse_60%_45%_at_50%_0%,color-mix(in_oklch,var(--color-brand-500)_15%,transparent)_0%,transparent_70%)]"
    >
    </div>
    <div
      class="mx-auto grid max-w-6xl gap-12 px-6 py-20 sm:py-24 lg:grid-cols-[1fr_1.15fr] lg:items-center lg:gap-16"
    >
      <div>
        <p class="text-brand-700 dark:text-brand-300 font-mono text-xs tracking-widest uppercase">
          open source · signed · reproducible
        </p>
        <h1
          class="mt-4 text-4xl leading-[1.05] font-semibold tracking-tight text-slate-900 sm:text-5xl lg:text-[3.4rem] dark:text-slate-50"
        >
          Cloud images
          <span
            class="from-brand-600 via-brand-500 to-brand-600 dark:from-brand-300 dark:via-brand-500 dark:to-brand-300 bg-gradient-to-r bg-clip-text text-transparent"
            >you can actually trust.</span
          >
        </h1>
        <p class="mt-5 max-w-xl text-lg text-slate-600 dark:text-slate-300/90">
          Cloud-init-ready, <strong class="font-semibold text-slate-900 dark:text-slate-100"
            >signed</strong
          >, reproducible qcow2 images for OpenStack and Proxmox — built in the open on GitHub
          Actions, with keyless cosign signatures and a public manifest for every release.
        </p>
        <div class="mt-7 flex flex-wrap gap-3">
          <a
            href="/images/"
            class="bg-brand-500 hover:bg-brand-600 inline-flex items-center gap-2 rounded-md px-5 py-2.5 text-sm font-medium text-white shadow-[0_8px_24px_-12px_rgba(91,141,239,0.6)] transition-colors"
          >
            Browse the catalog
            <svg viewBox="0 0 16 16" class="h-3.5 w-3.5" fill="none" aria-hidden="true">
              <path
                d="M9.5 3.5l4 4-4 4M2 7.5h11"
                stroke="currentColor"
                stroke-width="1.5"
                stroke-linecap="round"
                stroke-linejoin="round"></path>
            </svg>
          </a>
          <a
            href="https://github.com/open-img-cloud"
            class="inline-flex items-center gap-2 rounded-md border border-slate-300 px-5 py-2.5 text-sm font-medium text-slate-700 transition-colors hover:border-slate-400 hover:bg-slate-100 hover:text-slate-900 dark:border-slate-700 dark:text-slate-200 dark:hover:border-slate-500 dark:hover:bg-slate-900/40 dark:hover:text-slate-50"
          >
            <svg viewBox="0 0 16 16" class="h-4 w-4" fill="currentColor" aria-hidden="true">
              <path
                d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0 0 16 8c0-4.42-3.58-8-8-8z"
              ></path>
            </svg>
            View on GitHub
          </a>
        </div>
        <p class="mt-6 text-xs tracking-wide text-slate-500 dark:text-slate-400">
          Two commands away. Try it on{" "}
          <a
            href={`/images/${sampleOs}/`}
            class="text-brand-700 dark:text-brand-300 hover:underline"
            >{sample?.title ?? "Alpine Linux"}</a
          >.
        </p>
      </div>
      <div class="relative">
        <div
          aria-hidden="true"
          class="absolute -inset-6 -z-10 bg-[radial-gradient(circle_at_70%_30%,color-mix(in_oklch,var(--color-brand-500)_18%,transparent)_0%,transparent_60%)] blur-2xl"
        >
        </div>
        <Terminal title={`${sampleOs} @ v${sampleVersion}`}>
          <span class="t-line t-comment"># Verify the signature (keyless, GitHub OIDC)</span>
          <span class="t-line"
            ><span class="t-prompt">$</span><span class="t-cmd">cosign</span> verify-blob
            <span class="t-str">{sampleFile}</span> \</span
          >
          <span class="t-cont"
            ><span class="t-flag">--bundle</span>
            <span class="t-str">{sampleFile}.bundle</span> --new-bundle-format \</span
          >
          <span class="t-cont"><span class="t-flag">--certificate-identity-regexp</span> \</span>
          <span class="t-cont"><span class="t-str">'https://github.com/{sampleRepo}/'</span> \</span
          >
          <span class="t-cont"><span class="t-flag">--certificate-oidc-issuer</span> \</span>
          <span class="t-cont"
            ><span class="t-str">https://token.actions.githubusercontent.com</span></span
          >
          <span class="t-line t-ok">Verified OK</span>
          <span class="t-line">&nbsp;</span>
          <span class="t-line t-comment"># Upload to OpenStack — done.</span>
          <span class="t-line"
            ><span class="t-prompt">$</span><span class="t-cmd">openstack</span> image create \</span
          >
          <span class="t-cont"
            ><span class="t-flag">--disk-format</span> qcow2
            <span class="t-flag">--container-format</span> bare \</span
          >
          <span class="t-cont"
            ><span class="t-flag">--file</span> <span class="t-str">{sampleFile}</span> \</span
          >
          <span class="t-cont"><span class="t-str">{sampleOs}-{sampleVersion}</span></span>
          <span class="t-line t-out"
            >Created image <span class="t-ok">{sampleOs}-{sampleVersion}</span> · status:
            <span class="t-ok">active</span></span
          >
        </Terminal>
      </div>
    </div>
  </section>

  <section
    class="dark:bg-navy-900/30 border-t border-slate-200 bg-slate-50/70 dark:border-slate-800/60"
  >
    <div class="mx-auto grid max-w-6xl gap-8 px-6 py-20 sm:grid-cols-3">
      <div>
        <div
          class="bg-brand-500/15 text-brand-700 dark:text-brand-300 inline-flex h-9 w-9 items-center justify-center rounded-md"
        >
          <svg
            viewBox="0 0 24 24"
            class="h-5 w-5"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path d="M21 12a9 9 0 1 1-9-9 9 9 0 0 1 9 9z"></path>
            <path d="M12 7v5l3 2"></path>
          </svg>
        </div>
        <h3 class="mt-4 text-base font-semibold text-slate-900 dark:text-slate-100">
          Reproducible
        </h3>
        <p class="mt-2 text-sm text-slate-600 dark:text-slate-400">
          Every release is built from a pinned upstream source and a tagged builder container. The
          exact commit, run URL and builder digest are embedded in the per-image
          <code class="font-mono text-xs">MANIFEST.json</code>.
        </p>
      </div>
      <div>
        <div
          class="inline-flex h-9 w-9 items-center justify-center rounded-md bg-emerald-500/15 text-emerald-700 dark:text-emerald-300"
        >
          <svg
            viewBox="0 0 24 24"
            class="h-5 w-5"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
            <path d="M9 12l2 2 4-4"></path>
          </svg>
        </div>
        <h3 class="mt-4 text-base font-semibold text-slate-900 dark:text-slate-100">Signed</h3>
        <p class="mt-2 text-sm text-slate-600 dark:text-slate-400">
          Keyless <code class="font-mono text-xs">cosign</code> signatures via GitHub OIDC. Verify any
          image with a single command — no key management on your side.
        </p>
      </div>
      <div>
        <div
          class="bg-brand-700/25 text-brand-700 dark:text-brand-300 inline-flex h-9 w-9 items-center justify-center rounded-md"
        >
          <svg
            viewBox="0 0 24 24"
            class="h-5 w-5"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path d="M17.5 19a4.5 4.5 0 0 0 0-9 7 7 0 0 0-13.5 2.5A4.5 4.5 0 0 0 6 19"></path>
          </svg>
        </div>
        <h3 class="mt-4 text-base font-semibold text-slate-900 dark:text-slate-100">
          Open infrastructure
        </h3>
        <p class="mt-2 text-sm text-slate-600 dark:text-slate-400">
          Source of truth on a self-hosted Garage cluster, mirrored to Cloudflare R2 behind a public
          CDN. Reusable workflows in
          <a
            href="https://github.com/open-img-cloud/.github"
            class="text-brand-700 dark:text-brand-300 underline-offset-2 hover:underline">.github</a
          >
          power every image repo.
        </p>
      </div>
    </div>
  </section>

  <section class="border-t border-slate-200 dark:border-slate-800/60">
    <div class="mx-auto max-w-6xl px-6 py-20">
      <div class="flex items-baseline justify-between">
        <h2 class="text-2xl font-semibold tracking-tight text-slate-900 dark:text-slate-50">
          Featured images
        </h2>
        <a href="/images/" class="text-brand-700 hover:text-brand-500 dark:text-brand-300 text-sm"
          >All images →</a
        >
      </div>
      <div class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {featured.map((image) => <ImageCard image={image} />)}
      </div>
    </div>
  </section>
</Base>
