---
import Base from "~/layouts/Base.astro";
import CodeBlock from "~/components/CodeBlock.astro";
import { loadEnrichedImages, type EnrichedImage } from "~/lib/images";

export async function getStaticPaths() {
  const images = await loadEnrichedImages();
  return images.map((image) => ({
    params: { os: image.os_name },
    props: { image },
  }));
}

interface Props {
  image: EnrichedImage;
}

const { image } = Astro.props;
const repoUrl = `https://github.com/${image.repo}`;

type Row = {
  variantLabel: string | null;
  filename: string | null;
  fileUrl: string | null;
  manifestUrl: string;
  sha256: string | null;
  signed: boolean;
};

const rows: Row[] =
  image.enrichedVariants.length > 0
    ? image.enrichedVariants.map((v) => ({
        variantLabel: v.variant.label,
        filename: v.filename,
        fileUrl: v.fileUrl,
        manifestUrl: v.manifestUrl,
        sha256: v.manifest?.sha256 ?? null,
        signed: v.manifest?.signed ?? false,
      }))
    : [
        {
          variantLabel: null,
          filename: image.filename,
          fileUrl: image.fileUrl,
          manifestUrl: `https://images.openimages.cloud/${image.os_name}/${image.latest_version}/MANIFEST.json`,
          sha256: image.enrichedManifest?.sha256 ?? null,
          signed: image.enrichedManifest?.signed ?? false,
        },
      ];

const firstFileUrl = rows.find((r) => r.fileUrl)?.fileUrl ?? null;
const firstFilename = rows.find((r) => r.filename)?.filename ?? null;
const logoUrl = image.logo ? `/img/logos/${image.logo}` : null;

const chipClass =
  "rounded-md border border-slate-200 bg-slate-100 px-2 py-1 font-mono text-slate-700 dark:border-slate-700 dark:bg-slate-800/50 dark:text-slate-300";
const tagChipClass =
  "rounded-md border border-slate-200 bg-white px-2 py-1 text-slate-600 dark:border-slate-800 dark:bg-slate-900/40 dark:text-slate-400";
---

<Base title={image.title} description={image.tagline}>
  <article class="mx-auto max-w-4xl px-6 py-16">
    <nav class="text-sm text-slate-500 dark:text-slate-500">
      <a href="/images/" class="hover:text-slate-900 dark:hover:text-slate-300">Catalog</a>
      <span class="mx-2">/</span>
      <span class="text-slate-700 dark:text-slate-300">{image.title}</span>
    </nav>

    <header class="mt-6 flex items-start gap-4">
      {
        logoUrl && (
          <div class="flex h-14 w-14 shrink-0 items-center justify-center rounded-xl bg-slate-100 ring-1 ring-slate-200/80 dark:bg-slate-800/60 dark:ring-slate-700/60">
            <img
              src={logoUrl}
              alt=""
              width="36"
              height="36"
              loading="eager"
              decoding="async"
              class="h-9 w-9"
            />
          </div>
        )
      }
      <div class="flex-1">
        <h1 class="text-3xl font-semibold tracking-tight text-slate-900 dark:text-slate-50">
          {image.title}
        </h1>
        <p class="mt-2 text-slate-600 dark:text-slate-400">{image.tagline}</p>
        <div class="mt-4 flex flex-wrap items-center gap-2 text-xs">
          <span class={chipClass}>v{image.latest_version}</span>
          <span class={chipClass}>{image.format}</span>
          <span class={chipClass}>{image.arch}</span>
          {image.tags.map((tag) => <span class={tagChipClass}>{tag}</span>)}
        </div>
      </div>
    </header>

    <section class="mt-10">
      <h2 class="text-lg font-semibold text-slate-900 dark:text-slate-100">About</h2>
      <p class="mt-2 whitespace-pre-line text-slate-600 dark:text-slate-400">{image.description}</p>
      <ul class="mt-4 space-y-1 text-sm text-slate-600 dark:text-slate-400">
        <li>
          Source repository:{" "}
          <a
            class="text-brand-700 dark:text-brand-300 underline-offset-2 hover:underline"
            href={repoUrl}>{image.repo}</a
          >
        </li>
        {
          image.upstream_homepage && (
            <li>
              Upstream:{" "}
              <a
                class="text-brand-700 dark:text-brand-300 underline-offset-2 hover:underline"
                href={image.upstream_homepage}
              >
                {image.upstream_homepage}
              </a>
            </li>
          )
        }
      </ul>
    </section>

    <section class="mt-10">
      <h2 class="text-lg font-semibold text-slate-900 dark:text-slate-100">Downloads</h2>
      <div class="mt-4 overflow-x-auto rounded-lg border border-slate-200 dark:border-slate-800">
        <table class="w-full text-left text-sm">
          <thead
            class="bg-slate-50 text-xs tracking-wider text-slate-500 uppercase dark:bg-slate-900/60 dark:text-slate-400"
          >
            <tr>
              {image.enrichedVariants.length > 0 && <th class="px-4 py-3">Variant</th>}
              <th class="px-4 py-3">File</th>
              <th class="px-4 py-3">SHA-256</th>
              <th class="px-4 py-3">Signed</th>
              <th class="px-4 py-3">Manifest</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-200 dark:divide-slate-800/60">
            {
              rows.map((row) => (
                <tr class="hover:bg-slate-50 dark:hover:bg-slate-900/30">
                  {row.variantLabel !== null && (
                    <td class="px-4 py-3 font-mono text-slate-700 dark:text-slate-200">
                      {row.variantLabel}
                    </td>
                  )}
                  <td class="px-4 py-3">
                    {row.fileUrl ? (
                      <a
                        href={row.fileUrl}
                        class="text-brand-700 dark:text-brand-300 font-mono hover:underline"
                      >
                        {row.filename}
                      </a>
                    ) : (
                      <span class="text-slate-400 dark:text-slate-500">unavailable</span>
                    )}
                  </td>
                  <td class="px-4 py-3 font-mono text-xs break-all text-slate-500 dark:text-slate-400">
                    {row.sha256 ?? "—"}
                  </td>
                  <td class="px-4 py-3">
                    {row.signed ? (
                      <span class="text-emerald-600 dark:text-emerald-400">yes</span>
                    ) : (
                      <span class="text-slate-400 dark:text-slate-500">no</span>
                    )}
                  </td>
                  <td class="px-4 py-3">
                    <a
                      href={row.manifestUrl}
                      class="text-brand-700 dark:text-brand-300 hover:underline"
                    >
                      MANIFEST
                    </a>
                  </td>
                </tr>
              ))
            }
          </tbody>
        </table>
      </div>
    </section>

    {
      firstFileUrl && firstFilename && (
        <section class="mt-10">
          <h2 class="text-lg font-semibold text-slate-900 dark:text-slate-100">
            Verify the signature
          </h2>
          <p class="mt-2 text-sm text-slate-600 dark:text-slate-400">
            All releases are signed keylessly via GitHub OIDC. Verify with{" "}
            <a
              class="text-brand-700 dark:text-brand-300 underline-offset-2 hover:underline"
              href="https://docs.sigstore.dev/cosign/installation/"
            >
              cosign
            </a>
            :
          </p>
          <CodeBlock label="bash">
            {`curl -fLO ${firstFileUrl}\ncurl -fLO ${firstFileUrl}.bundle\n\ncosign verify-blob ${firstFilename} \\\n  --bundle ${firstFilename}.bundle \\\n  --new-bundle-format \\\n  --certificate-identity-regexp 'https://github.com/${image.repo}/' \\\n  --certificate-oidc-issuer https://token.actions.githubusercontent.com`}
          </CodeBlock>
        </section>
      )
    }

    {
      image.previousReleases.length > 0 && (
        <section class="mt-10">
          <h2 class="text-lg font-semibold text-slate-900 dark:text-slate-100">
            Previous releases
          </h2>
          <p class="mt-2 text-sm text-slate-600 dark:text-slate-400">
            Older versions remain available at their pinned, immutable paths — useful when your
            stack targets a specific OpenStack/cloud release.
          </p>
          <div class="mt-4 overflow-x-auto rounded-lg border border-slate-200 dark:border-slate-800">
            <table class="w-full text-left text-sm">
              <thead class="bg-slate-50 text-xs tracking-wider text-slate-500 uppercase dark:bg-slate-900/60 dark:text-slate-400">
                <tr>
                  <th class="px-4 py-3">Version</th>
                  <th class="px-4 py-3">File</th>
                  <th class="px-4 py-3">SHA-256</th>
                  <th class="px-4 py-3">Signed</th>
                  <th class="px-4 py-3">Manifest</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-slate-200 dark:divide-slate-800/60">
                {image.previousReleases.map((rel) => (
                  <tr class="hover:bg-slate-50 dark:hover:bg-slate-900/30">
                    <td class="px-4 py-3 font-mono text-slate-700 dark:text-slate-200">
                      {rel.version}
                    </td>
                    <td class="px-4 py-3">
                      {rel.fileUrl ? (
                        <a
                          href={rel.fileUrl}
                          class="text-brand-700 dark:text-brand-300 font-mono hover:underline"
                        >
                          {rel.filename}
                        </a>
                      ) : (
                        <span class="text-slate-400 dark:text-slate-500">unavailable</span>
                      )}
                    </td>
                    <td class="px-4 py-3 font-mono text-xs break-all text-slate-500 dark:text-slate-400">
                      {rel.sha256 ?? "—"}
                    </td>
                    <td class="px-4 py-3">
                      {rel.signed ? (
                        <span class="text-emerald-600 dark:text-emerald-400">yes</span>
                      ) : (
                        <span class="text-slate-400 dark:text-slate-500">no</span>
                      )}
                    </td>
                    <td class="px-4 py-3">
                      <a
                        href={rel.manifestUrl}
                        class="text-brand-700 dark:text-brand-300 hover:underline"
                      >
                        MANIFEST
                      </a>
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </section>
      )
    }

    <section class="mt-10">
      <h2 class="text-lg font-semibold text-slate-900 dark:text-slate-100">Use it</h2>
      <p class="mt-2 text-sm text-slate-600 dark:text-slate-400">Upload to OpenStack Glance:</p>
      {
        firstFileUrl && firstFilename && (
          <CodeBlock label="bash">
            {`openstack image create \\\n  --disk-format qcow2 \\\n  --container-format bare \\\n  --file ${firstFilename} \\\n  --public \\\n  ${image.os_name}-${image.latest_version}`}
          </CodeBlock>
        )
      }
    </section>
  </article>
</Base>
