---
import Base from "~/layouts/Base.astro";
import CodeBlock from "~/components/CodeBlock.astro";
import { loadEnrichedImages, type EnrichedImage } from "~/lib/images";

export async function getStaticPaths() {
  const images = await loadEnrichedImages();
  return images.map((image) => ({
    params: { os: image.os_name },
    props: { image },
  }));
}

interface Props {
  image: EnrichedImage;
}

const { image } = Astro.props;
const repoUrl = `https://github.com/${image.repo}`;

type Row = {
  variantLabel: string | null;
  filename: string | null;
  fileUrl: string | null;
  manifestUrl: string;
  sha256: string | null;
  signed: boolean;
};

const rows: Row[] =
  image.enrichedVariants.length > 0
    ? image.enrichedVariants.map((v) => ({
        variantLabel: v.variant.label,
        filename: v.filename,
        fileUrl: v.fileUrl,
        manifestUrl: v.manifestUrl,
        sha256: v.manifest?.sha256 ?? null,
        signed: v.manifest?.signed ?? false,
      }))
    : [
        {
          variantLabel: null,
          filename: image.filename,
          fileUrl: image.fileUrl,
          manifestUrl: `https://images.openimages.cloud/${image.os_name}/${image.latest_version}/MANIFEST.json`,
          sha256: image.enrichedManifest?.sha256 ?? null,
          signed: image.enrichedManifest?.signed ?? false,
        },
      ];

const firstFileUrl = rows.find((r) => r.fileUrl)?.fileUrl ?? null;
const firstFilename = rows.find((r) => r.filename)?.filename ?? null;
---

<Base title={image.title} description={image.tagline}>
  <article class="mx-auto max-w-4xl px-6 py-16">
    <nav class="text-sm text-zinc-500">
      <a href="/images/" class="hover:text-zinc-300">Catalog</a>
      <span class="mx-2">/</span>
      <span class="text-zinc-300">{image.title}</span>
    </nav>

    <header class="mt-6">
      <h1 class="text-3xl font-semibold tracking-tight text-zinc-50">{image.title}</h1>
      <p class="mt-2 text-zinc-400">{image.tagline}</p>
      <div class="mt-4 flex flex-wrap items-center gap-2 text-xs">
        <span
          class="rounded-md border border-zinc-700 bg-zinc-800/50 px-2 py-1 font-mono text-zinc-300"
        >
          v{image.latest_version}
        </span>
        <span
          class="rounded-md border border-zinc-700 bg-zinc-800/50 px-2 py-1 font-mono text-zinc-300"
        >
          {image.format}
        </span>
        <span
          class="rounded-md border border-zinc-700 bg-zinc-800/50 px-2 py-1 font-mono text-zinc-300"
        >
          {image.arch}
        </span>
        {
          image.tags.map((tag) => (
            <span class="rounded-md border border-zinc-800 bg-zinc-900/40 px-2 py-1 text-zinc-400">
              {tag}
            </span>
          ))
        }
      </div>
    </header>

    <section class="mt-10">
      <h2 class="text-lg font-semibold text-zinc-100">About</h2>
      <p class="mt-2 whitespace-pre-line text-zinc-400">{image.description}</p>
      <ul class="mt-4 space-y-1 text-sm text-zinc-400">
        <li>
          Source repository: <a class="underline hover:text-zinc-100" href={repoUrl}>{image.repo}</a
          >
        </li>
        {
          image.upstream_homepage && (
            <li>
              Upstream:{" "}
              <a class="underline hover:text-zinc-100" href={image.upstream_homepage}>
                {image.upstream_homepage}
              </a>
            </li>
          )
        }
      </ul>
    </section>

    <section class="mt-10">
      <h2 class="text-lg font-semibold text-zinc-100">Downloads</h2>
      <div class="mt-4 overflow-x-auto rounded-lg border border-zinc-800">
        <table class="w-full text-left text-sm">
          <thead class="bg-zinc-900/60 text-xs tracking-wider text-zinc-400 uppercase">
            <tr>
              {image.enrichedVariants.length > 0 && <th class="px-4 py-3">Variant</th>}
              <th class="px-4 py-3">File</th>
              <th class="px-4 py-3">SHA-256</th>
              <th class="px-4 py-3">Signed</th>
              <th class="px-4 py-3">Manifest</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-zinc-800/60">
            {
              rows.map((row) => (
                <tr class="hover:bg-zinc-900/30">
                  {row.variantLabel !== null && (
                    <td class="px-4 py-3 font-mono text-zinc-200">{row.variantLabel}</td>
                  )}
                  <td class="px-4 py-3">
                    {row.fileUrl ? (
                      <a href={row.fileUrl} class="text-brand-500 font-mono hover:underline">
                        {row.filename}
                      </a>
                    ) : (
                      <span class="text-zinc-500">unavailable</span>
                    )}
                  </td>
                  <td class="px-4 py-3 font-mono text-xs break-all text-zinc-400">
                    {row.sha256 ?? "—"}
                  </td>
                  <td class="px-4 py-3">
                    {row.signed ? (
                      <span class="text-emerald-400">yes</span>
                    ) : (
                      <span class="text-zinc-500">no</span>
                    )}
                  </td>
                  <td class="px-4 py-3">
                    <a href={row.manifestUrl} class="text-brand-500 hover:underline">
                      MANIFEST
                    </a>
                  </td>
                </tr>
              ))
            }
          </tbody>
        </table>
      </div>
    </section>

    {
      firstFileUrl && firstFilename && (
        <section class="mt-10">
          <h2 class="text-lg font-semibold text-zinc-100">Verify the signature</h2>
          <p class="mt-2 text-sm text-zinc-400">
            All releases are signed keylessly via GitHub OIDC. Verify with{" "}
            <a class="underline" href="https://docs.sigstore.dev/cosign/installation/">
              cosign
            </a>
            :
          </p>
          <CodeBlock label="bash">
            {`curl -fLO ${firstFileUrl}\ncurl -fLO ${firstFileUrl}.bundle\n\ncosign verify-blob ${firstFilename} \\\n  --bundle ${firstFilename}.bundle \\\n  --new-bundle-format \\\n  --certificate-identity-regexp 'https://github.com/${image.repo}/' \\\n  --certificate-oidc-issuer https://token.actions.githubusercontent.com`}
          </CodeBlock>
        </section>
      )
    }

    <section class="mt-10">
      <h2 class="text-lg font-semibold text-zinc-100">Use it</h2>
      <p class="mt-2 text-sm text-zinc-400">Upload to OpenStack Glance:</p>
      {
        firstFileUrl && firstFilename && (
          <CodeBlock label="bash">
            {`openstack image create \\\n  --disk-format qcow2 \\\n  --container-format bare \\\n  --file ${firstFilename} \\\n  --public \\\n  ${image.os_name}-${image.latest_version}`}
          </CodeBlock>
        )
      }
    </section>
  </article>
</Base>
