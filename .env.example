# Public site origin (used for sitemap and absolute URLs in metadata).
SITE_URL=https://openimages.cloud

# Base URL for the published image bucket (CDN in front of R2).
# Build-time fetch of MANIFEST.json files for the catalog.
IMAGES_BASE_URL=https://images.openimages.cloud

# GitHub organization slug (used for repo links on image detail pages).
GITHUB_ORG=open-img-cloud
